for file in $XDG_CONFIG_HOME/zsh/*.zsh; do
  source $file
done

# zsh-autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#3D444D'

touch ~/.hushlogin

# Run ssh-add check in background (~270ms saved from startup)
{
  key=$(ssh-add -l)
  if [ "${key}" = 'The agent has no identities.' ] && [ -e ~/.ssh/id_rsa ]; then
    ssh-add --apple-use-keychain
  fi
} &!
